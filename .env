# Server Configuration
PORT=8080
ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD="your_password"
DB_NAME=go_backend_api

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=24h

# Rate Limiting (optional)
RATE_LIMIT=100
RATE_LIMIT_DURATION=1m